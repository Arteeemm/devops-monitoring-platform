[Unit]
Description=DevOps Monitoring Platform
After=network.target

[Service]
Type=simple
User=st2
WorkingDirectory=/home/artyom/devops-monitoring-platform
ExecStart=/home/artyom/devops-monitoring-platform/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
